# Required - obtain from Anthropic
ANTHROPIC_API_KEY=your-key-here

# Model versions - update when Anthropic releases new versions
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6

# Embedding configuration
EMBEDDING_MODEL_NAME=all-mpnet-base-v2
EMBEDDING_MODE=dense

# Clustering and assignment thresholds
CENTROID_ALPHA=0.15
NOISE_BUFFER_THRESHOLD=200
ASSIGNMENT_SIMILARITY_FLOOR=0.45
CONFIDENCE_ESCALATION_THRESHOLD=0.60

# LLM token limits and budgets
HAIKU_MAX_TOKENS=512
SONNET_MAX_TOKENS=2048
SONNET_DAILY_TOKEN_BUDGET=200000

# LSH deduplication settings
LSH_THRESHOLD=0.85
LSH_NUM_PERM=128

# Signal computation parameters
VELOCITY_WINDOW_DAYS=7
ENTROPY_VOCAB_WINDOW=10

# File paths
ASSET_LIBRARY_PATH=./data/asset_library.pkl
DB_PATH=./data/narrative_engine.db
LSH_INDEX_PATH=./data/lsh_index.pkl
FAISS_INDEX_PATH=./data/faiss_index.pkl

# Ingestion settings
SCRAPE_MAX_THREADS=3
SYNC_BURST_WINDOW_SECONDS=300
SYNC_BURST_MIN_SOURCES=5

# Trusted domains for coordination detection exclusion
TRUSTED_DOMAINS=reuters.com,apnews.com,bloomberg.com,wsj.com,ft.com

# Optional API keys (leave empty to disable that source)

# Finnhub (optional — enables live stock prices)
# FINNHUB_API_KEY=

MARKETAUX_API_KEY=
NEWSDATA_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=narrative_engine/1.0

# API feature flags
ENABLE_MARKETAUX=true
ENABLE_NEWSDATA=true
ENABLE_REDDIT=true

# Phase 2: Additional data providers (leave empty to disable)
# TWELVE_DATA_API_KEY=
# COINGECKO_API_KEY=
# ENABLE_TWELVE_DATA=false
# ENABLE_COINGECKO=false

# SEC EDGAR filings (requires valid email for SEC User-Agent policy)
# ENABLE_EDGAR=false
# EDGAR_EMAIL=
# EDGAR_COMPANY_NAME=NarrativeIntelligenceEngine
# EDGAR_TICKERS=

# WebSocket relay settings
# WEBSOCKET_SYMBOLS_LIMIT=50
# PRICE_TICK_RETENTION_HOURS=48
# WEBSOCKET_FLUSH_INTERVAL_SECONDS=5
# WEBSOCKET_RECONNECT_MAX_DELAY_SECONDS=300
# ANALYTICS_BG_REFRESH_SECONDS=14400

# X/Twitter automated posting (optional)
# Option 1: Typefully (recommended — free tier: 15 posts/month, no X API credits needed)
# Get API key at typefully.com/settings → API. Get social_set_id via GET /v2/social-sets.
# TYPEFULLY_API_KEY=
# TYPEFULLY_SOCIAL_SET_ID=
# TYPEFULLY_ENABLED=false
# TYPEFULLY_DAILY_BUDGET=1
#
# Option 2: Direct X API (requires pay-per-use credits at developer.x.com)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=
# TWITTER_ENABLED=false
# TWITTER_DAILY_BUDGET=12

# Auth (leave as stub for single-user mode)
# AUTH_MODE=stub
# JWT_SECRET_KEY=
# JWT_EXPIRY_HOURS=24
